---
import {
  MESHTASTIC_CHILE,
  MESHCORE_CHILE,
  SOCIAL_LINKS,
  ECOSYSTEM_LINKS,
} from '../config/meshtastic-chile'
---

<footer style="background:#0f1724;border-top:1px solid #1f2937;color:#9ca3af;font-family:'Inter',system-ui,sans-serif">
  <div style="max-width:1200px;margin:0 auto;padding:3rem 1.5rem 2rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2.5rem">

    <!-- Identidad -->
    <div>
      <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="28" height="28" fill="none">
          <circle cx="6"  cy="16" r="4" fill="#10b981"/>
          <circle cx="20" cy="8"  r="3" fill="#2563eb"/>
          <circle cx="20" cy="24" r="3" fill="#2563eb"/>
          <line x1="6" y1="16" x2="20" y2="8"  stroke="#38bdf8" stroke-width="1.5"/>
          <line x1="6" y1="16" x2="20" y2="24" stroke="#38bdf8" stroke-width="1.5"/>
          <line x1="20" y1="8" x2="20" y2="24" stroke="#38bdf8" stroke-width="1.5"/>
        </svg>
        <span style="font-size:1.1rem;font-weight:700;color:#f9fafb">meshchile.cl <span style="color:#374151">·</span> meshea.me</span>
      </div>
      <p style="font-size:0.85rem;line-height:1.6">
        Hub de redes mesh LoRa comunitarias en Chile.
        Documentación, configuración y punto de entrada para recién llegados.
      </p>
    </div>

    <!-- Ecosistema -->
    <div>
      <h3 style="color:#f9fafb;font-size:0.9rem;font-weight:600;margin:0 0 0.75rem">Servicios</h3>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.4rem">
        <li><a href={ECOSYSTEM_LINKS.foro}  target="_blank" rel="noopener" style="color:#9ca3af;text-decoration:none;font-size:0.875rem" onmouseover="this.style.color='#f9fafb'" onmouseout="this.style.color='#9ca3af'">foro.meshchile.cl</a></li>
        <li><a href={ECOSYSTEM_LINKS.mapa}  target="_blank" rel="noopener" style="color:#9ca3af;text-decoration:none;font-size:0.875rem" onmouseover="this.style.color='#f9fafb'" onmouseout="this.style.color='#9ca3af'">mapa.meshea.me</a></li>
        <li><a href={ECOSYSTEM_LINKS.malla} target="_blank" rel="noopener" style="color:#9ca3af;text-decoration:none;font-size:0.875rem" onmouseover="this.style.color='#f9fafb'" onmouseout="this.style.color='#9ca3af'">malla.meshea.me</a></li>
        <li><a href={ECOSYSTEM_LINKS.vista} target="_blank" rel="noopener" style="color:#9ca3af;text-decoration:none;font-size:0.875rem" onmouseover="this.style.color='#f9fafb'" onmouseout="this.style.color='#9ca3af'">vista.meshea.me</a></li>
        <li><a href="/docs/lora" style="color:#9ca3af;text-decoration:none;font-size:0.875rem" onmouseover="this.style.color='#f9fafb'" onmouseout="this.style.color='#9ca3af'">Documentación</a></li>
      </ul>
    </div>

    <!-- Config Meshtastic Chile -->
    <div>
      <h3 style="color:#f9fafb;font-size:0.9rem;font-weight:600;margin:0 0 0.75rem">Config Meshtastic Chile</h3>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.35rem;font-size:0.8rem;font-family:'JetBrains Mono',ui-monospace,monospace">
        <li><span style="color:#f9fafb">Región:</span> {MESHTASTIC_CHILE.bandMhz} MHz ({MESHTASTIC_CHILE.region})</li>
        <li><span style="color:#f9fafb">Modem:</span> {MESHTASTIC_CHILE.modem} slot {MESHTASTIC_CHILE.slot}</li>
        <li><span style="color:#f9fafb">Frecuencia:</span> {MESHTASTIC_CHILE.freqMhz} MHz</li>
        <li><span style="color:#f9fafb">MQTT:</span> {MESHTASTIC_CHILE.mqtt.host}</li>
        <li><span style="color:#f9fafb">Topic:</span> {MESHTASTIC_CHILE.mqtt.rootTopic}</li>
      </ul>
    </div>

    <!-- Config MeshCore Chile -->
    <div>
      <h3 style="color:#f9fafb;font-size:0.9rem;font-weight:600;margin:0 0 0.75rem">Config MeshCore Chile</h3>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.35rem;font-size:0.8rem;font-family:'JetBrains Mono',ui-monospace,monospace">
        <li><span style="color:#f9fafb">Frecuencia:</span> {MESHCORE_CHILE.freqMhz} MHz</li>
        <li><span style="color:#f9fafb">BW:</span> {MESHCORE_CHILE.bandwidthKhz} kHz</li>
        <li><span style="color:#f9fafb">CR:</span> {MESHCORE_CHILE.codingRate}</li>
        <li><span style="color:#f9fafb">SF:</span> {MESHCORE_CHILE.spreadingFactor}</li>
      </ul>
    </div>

    <!-- Comunidad -->
    <div>
      <h3 style="color:#f9fafb;font-size:0.9rem;font-weight:600;margin:0 0 0.75rem">Comunidad</h3>
      <div style="display:flex;gap:1rem;margin-bottom:1rem">

        <!-- Telegram -->
        <a href={SOCIAL_LINKS.telegram} target="_blank" rel="noopener" title="Telegram" style="color:#9ca3af" onmouseover="this.style.color='#f9fafb'" onmouseout="this.style.color='#9ca3af'">
          <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
        </a>

        <!-- Discord -->
        <a href={SOCIAL_LINKS.discord} target="_blank" rel="noopener" title="Discord" style="color:#9ca3af" onmouseover="this.style.color='#f9fafb'" onmouseout="this.style.color='#9ca3af'">
          <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
        </a>

        <!-- WhatsApp -->
        <a href={SOCIAL_LINKS.whatsapp} target="_blank" rel="noopener" title="WhatsApp" style="color:#9ca3af" onmouseover="this.style.color='#f9fafb'" onmouseout="this.style.color='#9ca3af'">
          <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>

        <!-- Instagram -->
        <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noopener" title="Instagram" style="color:#9ca3af" onmouseover="this.style.color='#f9fafb'" onmouseout="this.style.color='#9ca3af'">
          <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        </a>

        <!-- Email -->
        <a href={SOCIAL_LINKS.email} title="Email" style="color:#9ca3af" onmouseover="this.style.color='#f9fafb'" onmouseout="this.style.color='#9ca3af'">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </a>

      </div>
    </div>

  </div>

  <div style="max-width:1200px;margin:0 auto;padding:1.25rem 1.5rem;border-top:1px solid #1f2937;display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:0.5rem;font-size:0.8rem">
    <span>&copy; {new Date().getFullYear()} meshchile.cl · meshea.me — comunidad mesh LoRa Chile</span>
    <span>Proyecto open source</span>
  </div>
</footer>
