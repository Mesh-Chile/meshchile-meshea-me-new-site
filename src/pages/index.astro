---
import { Image } from 'astro:assets'
import HomeLayout from '../layouts/HomeLayout.astro'
import Footer from '../components/Footer.astro'
import { ECOSYSTEM_LINKS } from '../config/meshtastic-chile'
import heroImg from '../assets/hero.png'
import techImg from '../assets/t-echo.jpg'
import hwImg   from '../assets/hardware.jpg'
---

<HomeLayout
  title="meshchile.cl · meshea.me — Redes mesh LoRa en Chile"
  description="Hub de redes mesh LoRa comunitarias en Chile. Documentación, configuración y punto de entrada para Meshtastic y MeshCore."
>

  <!-- Navbar -->
  <nav style="position:sticky;top:0;z-index:50;background:rgba(13,17,23,0.92);backdrop-filter:blur(8px);border-bottom:1px solid #1f2937;padding:0.75rem 1.5rem;display:flex;align-items:center;justify-content:space-between">
    <a href="/" style="display:flex;align-items:center;gap:0.5rem;text-decoration:none">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="26" height="26" fill="none">
        <circle cx="6"  cy="16" r="4" fill="#10b981"/>
        <circle cx="20" cy="8"  r="3" fill="#2563eb"/>
        <circle cx="20" cy="24" r="3" fill="#2563eb"/>
        <line x1="6" y1="16" x2="20" y2="8"  stroke="#38bdf8" stroke-width="1.5"/>
        <line x1="6" y1="16" x2="20" y2="24" stroke="#38bdf8" stroke-width="1.5"/>
        <line x1="20" y1="8" x2="20" y2="24" stroke="#38bdf8" stroke-width="1.5"/>
      </svg>
      <span style="font-weight:700;font-size:1rem;color:#f9fafb">meshchile.cl <span style="color:#374151">|</span> meshea.me</span>
    </a>
    <div style="display:flex;gap:1.5rem;align-items:center">
      <a href="/docs/lora"           style="color:#9ca3af;text-decoration:none;font-size:0.875rem">Docs</a>
      <a href="/comunidad"           style="color:#9ca3af;text-decoration:none;font-size:0.875rem">Comunidad</a>
      <a href={ECOSYSTEM_LINKS.mapa} target="_blank" rel="noopener" style="color:#9ca3af;text-decoration:none;font-size:0.875rem">Mapa</a>
      <a href={ECOSYSTEM_LINKS.foro} target="_blank" rel="noopener" style="color:#9ca3af;text-decoration:none;font-size:0.875rem">Foro</a>
      <a
        href={ECOSYSTEM_LINKS.foro}
        target="_blank" rel="noopener"
        style="background:#2563eb;color:#fff;padding:0.4rem 1rem;border-radius:6px;text-decoration:none;font-size:0.875rem;font-weight:500"
      >Únete</a>
    </div>
  </nav>

  <main>

    <!-- Hero — split layout -->
    <section style="min-height:90vh;display:grid;grid-template-columns:1fr 1fr;align-items:center;gap:3rem;padding:4rem 1.5rem;max-width:1200px;margin:0 auto">

      <div>
        <div style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(37,99,235,0.15);border:1px solid rgba(37,99,235,0.3);padding:0.3rem 0.75rem;border-radius:999px;font-size:0.8rem;color:#93c5fd;margin-bottom:1.5rem">
          <span style="width:6px;height:6px;border-radius:50%;background:#10b981;display:inline-block"></span>
          Red activa en Chile — LoRa 915–928 MHz
        </div>
        <h1 style="font-size:clamp(2.2rem,4vw,3.5rem);font-weight:700;line-height:1.15;margin:0 0 1.25rem;color:#f9fafb">
          Comunicación sin límites<br/>
          <span style="color:#10b981">con redes mesh</span>
        </h1>
        <p style="font-size:1.1rem;color:#9ca3af;line-height:1.75;margin:0 0 2rem">
          Mensajes de texto, GPS y datos de sensores a kilómetros de distancia,
          sin internet ni infraestructura celular. Hardware accesible, software
          libre, comunidad activa en Chile.
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem">
          <a href="/docs/lora" style="background:#2563eb;color:#fff;padding:0.7rem 1.5rem;border-radius:8px;text-decoration:none;font-weight:600;font-size:0.95rem">
            Empezar aquí
          </a>
          <a href={ECOSYSTEM_LINKS.mapa} target="_blank" rel="noopener" style="border:1px solid #374151;color:#d1d5db;padding:0.7rem 1.5rem;border-radius:8px;text-decoration:none;font-weight:500;font-size:0.95rem">
            Ver mapa de nodos
          </a>
        </div>
      </div>

      <div style="border-radius:16px;overflow:hidden;border:1px solid #1f2937;box-shadow:0 0 60px rgba(37,99,235,0.15)">
        <Image
          src={heroImg}
          alt="Dispositivos Heltec y T-Echo con bandera chilena y logo LoRa"
          width={768}
          quality={85}
          style="width:100%;height:auto;display:block"
        />
      </div>

    </section>

    <!-- ¿Qué es una red mesh LoRa? — split con foto -->
    <section style="padding:5rem 1.5rem;border-top:1px solid #1f2937;background:#0a0e1a">
      <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center">

        <div style="border-radius:14px;overflow:hidden;border:1px solid #1f2937">
          <Image
            src={techImg}
            alt="Dos dispositivos LilyGo T-Echo frente al mar"
            width={600}
            quality={85}
            style="width:100%;height:auto;display:block"
          />
        </div>

        <div>
          <h2 style="font-size:1.9rem;font-weight:700;color:#f9fafb;margin:0 0 1rem">¿Qué es una red mesh LoRa?</h2>
          <p style="font-size:1rem;color:#9ca3af;line-height:1.8;margin:0 0 1rem">
            Una red mesh distribuye la comunicación entre todos los nodos: cada dispositivo
            puede reenviar mensajes de otros, extendiendo el alcance sin punto central de falla.
          </p>
          <p style="font-size:1rem;color:#9ca3af;line-height:1.8;margin:0 0 1.5rem">
            LoRa (Long Range) es la tecnología de radio que lo hace posible en la banda 915–928 MHz,
            con alcances de varios kilómetros por nodo y consumo de energía mínimo.
          </p>
          <a href="/docs/mesh" style="color:#38bdf8;text-decoration:none;font-size:0.95rem;font-weight:500">
            Leer más en la documentación →
          </a>
        </div>

      </div>
    </section>

    <!-- Redes activas en Chile -->
    <section style="padding:5rem 1.5rem;border-top:1px solid #1f2937">
      <div style="max-width:1000px;margin:0 auto">
        <h2 style="font-size:1.9rem;font-weight:700;color:#f9fafb;text-align:center;margin:0 0 0.75rem">Redes activas en Chile</h2>
        <p style="color:#9ca3af;text-align:center;margin:0 0 3rem">
          Dos frameworks, el mismo hardware. Elige el que mejor se adapta a tu caso.
        </p>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem">

          <!-- Meshtastic card -->
          <div style="border:1px solid #1d4ed8;border-radius:12px;padding:1.75rem;background:rgba(37,99,235,0.06)">
            <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.5rem">
              <span style="font-size:1.2rem;font-weight:700;color:#93c5fd">Meshtastic</span>
              <span style="background:#1d4ed8;color:#bfdbfe;font-size:0.7rem;font-weight:600;padding:0.15rem 0.5rem;border-radius:999px">Consolidado</span>
            </div>
            <p style="color:#9ca3af;font-size:0.9rem;line-height:1.65;margin:0 0 1.25rem">
              Firmware open source maduro, app móvil oficial, comunidad global.
              La opción recomendada para empezar.
            </p>
            <ul style="list-style:none;padding:0;margin:0 0 1.5rem;display:flex;flex-direction:column;gap:0.35rem">
              <li style="color:#9ca3af;font-size:0.85rem">→ <a href={ECOSYSTEM_LINKS.mapa}  target="_blank" rel="noopener" style="color:#93c5fd;text-decoration:none">mapa.meshea.me</a></li>
              <li style="color:#9ca3af;font-size:0.85rem">→ <a href={ECOSYSTEM_LINKS.malla} target="_blank" rel="noopener" style="color:#93c5fd;text-decoration:none">malla.meshea.me</a></li>
              <li style="color:#9ca3af;font-size:0.85rem">→ <a href={ECOSYSTEM_LINKS.vista} target="_blank" rel="noopener" style="color:#93c5fd;text-decoration:none">vista.meshea.me</a></li>
            </ul>
            <a href="/docs/meshtastic/intro" style="display:inline-block;background:#2563eb;color:#fff;padding:0.55rem 1.25rem;border-radius:6px;text-decoration:none;font-size:0.875rem;font-weight:500">Ver documentación</a>
          </div>

          <!-- MeshCore card -->
          <div style="border:1px solid #374151;border-radius:12px;padding:1.75rem;background:rgba(255,255,255,0.02)">
            <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.5rem">
              <span style="font-size:1.2rem;font-weight:700;color:#d1d5db">MeshCore</span>
              <span style="background:#451a03;color:#fed7aa;font-size:0.7rem;font-weight:600;padding:0.15rem 0.5rem;border-radius:999px">Exploratorio</span>
            </div>
            <p style="color:#9ca3af;font-size:0.9rem;line-height:1.65;margin:0 0 1.25rem">
              Protocolo alternativo con enfoque en repeaters y eficiencia de
              espectro. En evaluación activa por la comunidad.
            </p>
            <ul style="list-style:none;padding:0;margin:0 0 1.5rem">
              <li style="color:#6b7280;font-size:0.85rem;font-style:italic">Herramientas de monitoreo — próximamente</li>
            </ul>
            <a href="/docs/meshcore/intro" style="display:inline-block;border:1px solid #374151;color:#d1d5db;padding:0.55rem 1.25rem;border-radius:6px;text-decoration:none;font-size:0.875rem;font-weight:500">Ver documentación</a>
          </div>

        </div>
      </div>
    </section>

    <!-- Cómo sumarte — con foto de hardware -->
    <section style="padding:5rem 1.5rem;border-top:1px solid #1f2937;background:#0a0e1a">
      <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center">

        <div>
          <h2 style="font-size:1.9rem;font-weight:700;color:#f9fafb;margin:0 0 2.5rem">Cómo sumarte</h2>
          <ol style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:1.75rem">
            <li style="display:flex;gap:1.25rem;align-items:flex-start">
              <span style="flex-shrink:0;width:36px;height:36px;background:#1d4ed8;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;color:#bfdbfe;font-size:0.95rem">1</span>
              <div>
                <strong style="color:#f9fafb;display:block;margin-bottom:0.3rem">Consigue hardware compatible</strong>
                <span style="color:#9ca3af;font-size:0.9rem">Heltec V3, T-Beam, RAK Wisblock — el mismo hardware sirve para ambos firmwares. <a href="/docs/hardware" style="color:#38bdf8;text-decoration:none">Ver guía →</a></span>
              </div>
            </li>
            <li style="display:flex;gap:1.25rem;align-items:flex-start">
              <span style="flex-shrink:0;width:36px;height:36px;background:#1d4ed8;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;color:#bfdbfe;font-size:0.95rem">2</span>
              <div>
                <strong style="color:#f9fafb;display:block;margin-bottom:0.3rem">Elige tu framework</strong>
                <span style="color:#9ca3af;font-size:0.9rem">¿No sabes cuál? <a href="/docs/cual-elegir" style="color:#38bdf8;text-decoration:none">Esta guía te ayuda a decidir →</a></span>
              </div>
            </li>
            <li style="display:flex;gap:1.25rem;align-items:flex-start">
              <span style="flex-shrink:0;width:36px;height:36px;background:#1d4ed8;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;color:#bfdbfe;font-size:0.95rem">3</span>
              <div>
                <strong style="color:#f9fafb;display:block;margin-bottom:0.3rem">Únete al foro</strong>
                <span style="color:#9ca3af;font-size:0.9rem">La conversación, las dudas y la coordinación viven en <a href={ECOSYSTEM_LINKS.foro} target="_blank" rel="noopener" style="color:#38bdf8;text-decoration:none">foro.meshchile.cl →</a></span>
              </div>
            </li>
          </ol>
        </div>

        <div style="border-radius:14px;overflow:hidden;border:1px solid #1f2937">
          <Image
            src={hwImg}
            alt="Variedad de dispositivos LoRa para redes mesh"
            width={600}
            quality={85}
            style="width:100%;height:auto;display:block"
          />
        </div>

      </div>
    </section>

  </main>

  <Footer />

</HomeLayout>
