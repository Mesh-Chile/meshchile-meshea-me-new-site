---
import { getCollection } from 'astro:content'
import HomeLayout from '../../layouts/HomeLayout.astro'
import Footer from '../../components/Footer.astro'
import { ECOSYSTEM_LINKS } from '../../config/meshtastic-chile'

const operators = await getCollection('operators')

const regions = [...new Set(operators.map(op => op.data.location.region))].sort()

const REGION_LABELS: Record<string, string> = {
  'Metropolitana': 'RM',
  'Valparaíso': 'V',
  'Biobío': 'VIII',
  'Antofagasta': 'II',
  'Araucanía': 'IX',
  'Los Lagos': 'X',
  'Atacama': 'III',
  'Coquimbo': 'IV',
  "O'Higgins": 'VI',
  'Maule': 'VII',
  'Los Ríos': 'XIV',
  'Aysén': 'XI',
  'Magallanes': 'XII',
  'Tarapacá': 'I',
  'Arica y Parinacota': 'XV',
  'Ñuble': 'XVI',
}

function roleLabel(roles: string[]) {
  if (roles.includes('coordinator')) return 'Coordinador'
  if (roles.includes('contributor')) return 'Contribuidor'
  return 'Operador'
}

function frameworkBadge(fw: string) {
  if (fw === 'meshtastic') return { label: 'Meshtastic', bg: 'rgba(37,99,235,0.15)', border: '#1d4ed8', color: '#93c5fd' }
  return { label: 'MeshCore', bg: 'rgba(245,158,11,0.12)', border: '#78350f', color: '#fcd34d' }
}
---

<HomeLayout
  title="Comunidad de operadores — meshea.me"
  description="Directorio de operadores de la red mesh LoRa en Chile. Personas y colectivos que hacen posible la red."
>
  <nav style="position:sticky;top:0;z-index:50;background:rgba(13,17,23,0.92);backdrop-filter:blur(8px);border-bottom:1px solid #1f2937;padding:0.75rem 1.5rem;display:flex;align-items:center;justify-content:space-between">
    <a href="/" style="display:flex;align-items:center;gap:0.5rem;text-decoration:none">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="26" height="26" fill="none">
        <circle cx="6"  cy="16" r="4" fill="#10b981"/>
        <circle cx="20" cy="8"  r="3" fill="#2563eb"/>
        <circle cx="20" cy="24" r="3" fill="#2563eb"/>
        <line x1="6" y1="16" x2="20" y2="8"  stroke="#38bdf8" stroke-width="1.5"/>
        <line x1="6" y1="16" x2="20" y2="24" stroke="#38bdf8" stroke-width="1.5"/>
        <line x1="20" y1="8" x2="20" y2="24" stroke="#38bdf8" stroke-width="1.5"/>
      </svg>
      <span style="font-weight:700;font-size:1rem;color:#f9fafb">meshchile.cl <span style="color:#374151">|</span> meshea.me</span>
    </a>
    <div style="display:flex;gap:1.5rem;align-items:center">
      <a href="/docs/lora"           style="color:#9ca3af;text-decoration:none;font-size:0.875rem">Docs</a>
      <a href="/comunidad"           style="color:#f9fafb;text-decoration:none;font-size:0.875rem;font-weight:500">Comunidad</a>
      <a href={ECOSYSTEM_LINKS.mapa} target="_blank" rel="noopener" style="color:#9ca3af;text-decoration:none;font-size:0.875rem">Mapa</a>
      <a href={ECOSYSTEM_LINKS.foro} target="_blank" rel="noopener" style="color:#9ca3af;text-decoration:none;font-size:0.875rem">Foro</a>
      <a href="/comunidad/agregar" style="background:#2563eb;color:#fff;padding:0.4rem 1rem;border-radius:6px;text-decoration:none;font-size:0.875rem;font-weight:500">
        + Agregar perfil
      </a>
    </div>
  </nav>

  <main style="max-width:1200px;margin:0 auto;padding:3rem 1.5rem">

    <div style="margin-bottom:3rem">
      <h1 style="font-size:2.2rem;font-weight:700;color:#f9fafb;margin:0 0 0.75rem">
        Directorio de operadores
      </h1>
      <p style="color:#9ca3af;font-size:1.05rem;max-width:640px;line-height:1.7;margin:0 0 1.5rem">
        Las personas y colectivos que operan la red mesh LoRa en Chile.
        Cada perfil es gestionado por su propio operador vía PR en GitHub.
      </p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap">
        <a href="/comunidad/mapa" style="display:inline-flex;align-items:center;gap:0.4rem;border:1px solid #374151;color:#d1d5db;padding:0.5rem 1rem;border-radius:6px;text-decoration:none;font-size:0.875rem">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 13l4.553 2.276A1 1 0 0021 21.382V10.618a1 1 0 00-.553-.894L15 7m0 13V7m0 0L9 4"/></svg>
          Ver en mapa
        </a>
        <a href="/comunidad/agregar" style="display:inline-flex;align-items:center;gap:0.4rem;background:rgba(37,99,235,0.12);border:1px solid rgba(37,99,235,0.3);color:#93c5fd;padding:0.5rem 1rem;border-radius:6px;text-decoration:none;font-size:0.875rem">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          Registrar mi perfil
        </a>
      </div>
    </div>

    <!-- Filtros -->
    <div id="filtros" style="background:#0a0e1a;border:1px solid #1f2937;border-radius:10px;padding:1.25rem;margin-bottom:2rem;display:flex;flex-wrap:wrap;gap:1rem;align-items:center">
      <div style="display:flex;flex-direction:column;gap:0.35rem">
        <label for="filtro-region" style="color:#6b7280;font-size:0.75rem;font-weight:500;text-transform:uppercase;letter-spacing:0.05em">Región</label>
        <select id="filtro-region" style="background:#111827;border:1px solid #374151;color:#d1d5db;padding:0.4rem 0.75rem;border-radius:6px;font-size:0.875rem;cursor:pointer">
          <option value="">Todas</option>
          {regions.map(r => <option value={r}>{r}</option>)}
        </select>
      </div>

      <div style="display:flex;flex-direction:column;gap:0.35rem">
        <label for="filtro-framework" style="color:#6b7280;font-size:0.75rem;font-weight:500;text-transform:uppercase;letter-spacing:0.05em">Framework</label>
        <select id="filtro-framework" style="background:#111827;border:1px solid #374151;color:#d1d5db;padding:0.4rem 0.75rem;border-radius:6px;font-size:0.875rem;cursor:pointer">
          <option value="">Todos</option>
          <option value="meshtastic">Meshtastic</option>
          <option value="meshcore">MeshCore</option>
        </select>
      </div>

      <div style="display:flex;flex-direction:column;gap:0.35rem">
        <label for="filtro-rol" style="color:#6b7280;font-size:0.75rem;font-weight:500;text-transform:uppercase;letter-spacing:0.05em">Rol</label>
        <select id="filtro-rol" style="background:#111827;border:1px solid #374151;color:#d1d5db;padding:0.4rem 0.75rem;border-radius:6px;font-size:0.875rem;cursor:pointer">
          <option value="">Todos</option>
          <option value="coordinator">Coordinadores</option>
          <option value="operator">Operadores</option>
          <option value="contributor">Contribuidores</option>
        </select>
      </div>

      <div style="display:flex;align-items:flex-end;padding-bottom:0.1rem">
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;color:#9ca3af;font-size:0.875rem">
          <input type="checkbox" id="filtro-ayuda" style="width:16px;height:16px;accent-color:#2563eb;cursor:pointer" />
          Ayuda a recién llegados
        </label>
      </div>

      <div style="display:flex;align-items:flex-end;padding-bottom:0.1rem;margin-left:auto">
        <span id="conteo-operadores" style="color:#6b7280;font-size:0.85rem">{operators.length} operadores</span>
      </div>
    </div>

    <!-- Grid de operadores -->
    <div id="grid-operadores" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.25rem">
      {operators.map(op => {
        const d = op.data
        const primaryRole = roleLabel(d.role)
        const isCoord = d.role.includes('coordinator')
        return (
          <a
            href={`/comunidad/${op.id}`}
            class="operator-card"
            data-region={d.location.region}
            data-frameworks={d.frameworks.join(',')}
            data-roles={d.role.join(',')}
            data-helps={d.availability.helpsNewcomers ? 'true' : 'false'}
            style={`display:block;border:1px solid ${isCoord ? '#1d4ed8' : '#1f2937'};border-radius:12px;padding:1.5rem;background:${isCoord ? 'rgba(37,99,235,0.05)' : 'rgba(255,255,255,0.02)'};text-decoration:none;transition:border-color 0.15s,background 0.15s`}
          >
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.75rem">
              <div>
                <div style="font-weight:600;color:#f9fafb;font-size:1.05rem;margin-bottom:0.2rem">{d.displayName}</div>
                {d.alias && d.alias.length > 0 && (
                  <div style="font-size:0.75rem;color:#6b7280;font-family:'JetBrains Mono',monospace">{d.alias.slice(0,2).join(' · ')}</div>
                )}
              </div>
              <span style={`font-size:0.7rem;font-weight:600;padding:0.2rem 0.55rem;border-radius:999px;flex-shrink:0;background:${isCoord ? 'rgba(37,99,235,0.25)' : 'rgba(255,255,255,0.06)'};color:${isCoord ? '#93c5fd' : '#9ca3af'}`}>
                {primaryRole}
              </span>
            </div>

            <div style="display:flex;align-items:center;gap:0.4rem;margin-bottom:0.9rem;color:#9ca3af;font-size:0.825rem">
              <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span>{d.location.commune ? `${d.location.commune}, ` : ''}{d.location.region}</span>
            </div>

            <div style="display:flex;gap:0.4rem;flex-wrap:wrap;margin-bottom:0.9rem">
              {d.frameworks.map(fw => {
                const b = frameworkBadge(fw)
                return (
                  <span style={`background:${b.bg};border:1px solid ${b.border};color:${b.color};font-size:0.7rem;font-weight:600;padding:0.15rem 0.5rem;border-radius:999px`}>
                    {b.label}
                  </span>
                )
              })}
              {d.availability.helpsNewcomers && (
                <span style="background:rgba(16,185,129,0.12);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;font-size:0.7rem;font-weight:600;padding:0.15rem 0.5rem;border-radius:999px">
                  Ayuda a newbies
                </span>
              )}
            </div>

            {d.nodes && d.nodes.length > 0 && (
              <div style="font-size:0.8rem;color:#6b7280">
                {d.nodes.filter(n => n.active).length} nodo{d.nodes.filter(n => n.active).length !== 1 ? 's' : ''} activo{d.nodes.filter(n => n.active).length !== 1 ? 's' : ''}
              </div>
            )}

            {d.tags.length > 0 && (
              <div style="display:flex;gap:0.35rem;flex-wrap:wrap;margin-top:0.75rem">
                {d.tags.slice(0,3).map(tag => (
                  <span style="background:#111827;color:#6b7280;font-size:0.7rem;padding:0.1rem 0.45rem;border-radius:4px">#{tag}</span>
                ))}
              </div>
            )}
          </a>
        )
      })}
    </div>

    <div id="sin-resultados" style="display:none;text-align:center;padding:4rem 1rem;color:#6b7280">
      <p style="font-size:1.1rem;margin-bottom:0.5rem">Ningún operador coincide con los filtros.</p>
      <p style="font-size:0.875rem">Prueba cambiando los filtros o <a href="/comunidad/agregar" style="color:#38bdf8;text-decoration:none">registra tu perfil</a>.</p>
    </div>

  </main>

  <Footer />
</HomeLayout>

<script>
  function applyFilters() {
    const region    = (document.getElementById('filtro-region')    as HTMLSelectElement).value
    const framework = (document.getElementById('filtro-framework') as HTMLSelectElement).value
    const rol       = (document.getElementById('filtro-rol')       as HTMLSelectElement).value
    const ayuda     = (document.getElementById('filtro-ayuda')     as HTMLInputElement).checked

    const cards = document.querySelectorAll<HTMLElement>('.operator-card')
    let visible = 0

    cards.forEach(card => {
      const matchRegion    = !region    || card.dataset.region === region
      const matchFramework = !framework || card.dataset.frameworks!.split(',').includes(framework)
      const matchRol       = !rol       || card.dataset.roles!.split(',').includes(rol)
      const matchAyuda     = !ayuda     || card.dataset.helps === 'true'

      const show = matchRegion && matchFramework && matchRol && matchAyuda
      card.style.display = show ? 'block' : 'none'
      if (show) visible++
    })

    const conteo = document.getElementById('conteo-operadores')
    if (conteo) conteo.textContent = `${visible} operador${visible !== 1 ? 'es' : ''}`

    const sinRes = document.getElementById('sin-resultados') as HTMLElement
    sinRes.style.display = visible === 0 ? 'block' : 'none'
  }

  document.getElementById('filtro-region')?.addEventListener('change', applyFilters)
  document.getElementById('filtro-framework')?.addEventListener('change', applyFilters)
  document.getElementById('filtro-rol')?.addEventListener('change', applyFilters)
  document.getElementById('filtro-ayuda')?.addEventListener('change', applyFilters)
</script>
